<?php

$plus = 0;
$minus = 1;

$on_time = 9900;
$off_time = 100;

gpio_mode($plus, 1);
gpio_mode($minus, 1);

while (true) {
	/*
	 * 9.9ms + 0.1ms + 9.9ms + 0.1ms = 20ms = 50Hz
	 */
	gpio_write($plus, 1);
	gpio_write($minus, 0);
	sleep_us($on_time);
	gpio_write($plus, 0);
	gpio_write($minus, 0);
	sleep_us($off_time);
	gpio_write($plus, 0);
	gpio_write($minus, 1);
	sleep_us($on_time);
	gpio_write($plus, 0);
	gpio_write($minus, 0);
	sleep_us($off_time);
}
